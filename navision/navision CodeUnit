PROCEDURE ConvertPdfToZugFerd@50000();
BEGIN
    // 1. Pfade vorbereiten
    ApiUrl     := 'http://168.119.100.89:8084/api/v1/convert';
    TempFolder := DotNetPath.GetTempPath + 'zugferd_' + DELCHR(FORMAT(CREATEGUID()), '=', '{}');
    PDFPath    := TempFolder + '\invoice.pdf';
    XMLPath    := TempFolder + '\invoice.xml';
    OutPath    := TempFolder + '\invoice_zugferd.pdf';

    // 2. Ordner erstellen + Dateien kopieren
    DotNetDirectory.CreateDirectory(TempFolder);
    DotNetFile.Copy('\\bc\e$\Test\ZugFerd_Gutschrift.pdf', PDFPath, TRUE);
    DotNetFile.Copy('\\bc\e$\Test\ZugFerd_Gutschrift.xml', XMLPath, TRUE);

    // 3. Multipart aufbauen
    MultipartContent := MultipartContent.MultipartFormDataContent();

    PdfContent := PdfContent.ByteArrayContent(DotNetFile.ReadAllBytes(PDFPath));
    MultipartContent.Add(PdfContent, 'file', 'invoice.pdf');

    XmlContent := XmlContent.ByteArrayContent(DotNetFile.ReadAllBytes(XMLPath));
    MultipartContent.Add(XmlContent, 'xmlFile', 'invoice.xml');

    ProfileContent := ProfileContent.StringContent('BASIC');
    MultipartContent.Add(ProfileContent, 'profile');

    // 4. POST senden
    HttpClient := HttpClient.HttpClient();
    Response   := HttpClient.PostAsync(ApiUrl, MultipartContent).Result;

    IF Response.StatusCode <> 200 THEN
        ERROR('API Fehler: %1', Response.ReasonPhrase);

    // 5. ZUGFeRD PDF speichern
    DotNetFile.WriteAllBytes(OutPath, Response.Content.ReadAsByteArrayAsync().Result);

    // 6. Response Headers lesen
    RespHeaders := Response.Headers;

    IF RespHeaders.Contains('X-XML-Validation-Errors') THEN BEGIN
        HdrEnum := RespHeaders.GetValues('X-XML-Validation-Errors').GetEnumerator();
        IF HdrEnum.MoveNext THEN
            XmlErrors := FORMAT(HdrEnum.Current);
    END;

    IF RespHeaders.Contains('X-PDF-Validation-Errors') THEN BEGIN
        HdrEnum := RespHeaders.GetValues('X-PDF-Validation-Errors').GetEnumerator();
        IF HdrEnum.MoveNext THEN
            PdfErrors := FORMAT(HdrEnum.Current);
    END;

    IF RespHeaders.Contains('X-PDFA3-Validation-Errors') THEN BEGIN
        HdrEnum := RespHeaders.GetValues('X-PDFA3-Validation-Errors').GetEnumerator();
        IF HdrEnum.MoveNext THEN
            PdfA3Errors := FORMAT(HdrEnum.Current);
    END;

    // 7. Ergebnis anzeigen
    MESSAGE('ZUGFeRD PDF: %1\n\nXML Errors: %2\nPDF Errors: %3\nPDF/A-3 Errors: %4',
        OutPath, XmlErrors, PdfErrors, PdfA3Errors);
END;
